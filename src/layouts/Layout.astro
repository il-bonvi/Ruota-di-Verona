---
const { title, eyebrow, subtitle, backLink, backLabel } = Astro.props;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Ruota di Verona</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0e0f11;
      --surface: #16181c;
      --surface2: #1e2026;
      --border: rgba(255,255,255,0.08);
      --border-hover: rgba(255,255,255,0.18);
      --text: #f0f0f0;
      --muted: #888;
      --accent: #6ee7b7;
      --red: #f87171;
      --yellow: #fbbf24;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Nunito', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      padding: 2rem;
    }

    header {
      max-width: 820px;
      margin: 0 auto 2.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 2rem;
    }

    .back {
      display: inline-block;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 1.5rem;
      transition: color 0.15s;
    }
    .back:hover { color: var(--text); }

    .eyebrow {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    h1 {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .subtitle { color: var(--muted); font-size: 14px; }

    main {
      max-width: 820px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
      margin-bottom: 1rem;
    }

    footer {
      max-width: 820px;
      margin: 4rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--muted);
      text-align: center;
    }
  </style>
</head>
<body>
  <header>
    {backLink && <a href={backLink} class="back">← {backLabel || 'Home'}</a>}
    {eyebrow && <div class="eyebrow">{eyebrow}</div>}
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </header>

  <main>
    <slot />
  </main>

  <footer>
    Ruota di Verona · UNI Hub
  </footer>
</body>
</html>