---
const materie = [
  {
    nome: "Controllo Biomedico",
    sigla: "CBM",
    domande: 60,
    link: "/quiz_cbm",
    colore: "#6ee7b7"
  }
]
---

<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ruota di Verona</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0e0f11;
      --surface: #16181c;
      --surface2: #1e2026;
      --border: rgba(255,255,255,0.08);
      --text: #f0f0f0;
      --muted: #888;
      --accent: #6ee7b7;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Nunito', sans-serif;
      min-height: 100vh;
      padding: 2rem;
    }

    header {
      max-width: 820px;
      margin: 0 auto 3rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 2rem;
    }

    .eyebrow {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      color: var(--muted);
      font-size: 14px;
    }

    main {
      max-width: 820px;
      margin: 0 auto;
    }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .materie-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
    }

    .materia-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.2s, transform 0.2s;
      display: block;
    }

    .materia-card:hover {
      border-color: var(--border-hover, rgba(255,255,255,0.18));
      transform: translateY(-2px);
    }

    .card-sigla {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
      padding: 3px 8px;
      border-radius: 6px;
      display: inline-block;
      background: var(--surface2);
    }

    .card-nome {
      font-size: 16px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    .card-meta {
      font-size: 12px;
      color: var(--muted);
    }

    .card-arrow {
      margin-top: 1.25rem;
      font-size: 18px;
    }
  </style>
</head>
<body>
  <header>
    <div class="eyebrow">Study Hub</div>
    <h1>Ruota di Verona</h1>
    <p class="subtitle">Quiz, appunti e approfondimenti per l'università.</p>
  </header>

  <main>
    <div class="section-label">Materie</div>
    <div class="materie-grid">
      {materie.map(m => (
        <a href={m.link} class="materia-card" style={`border-top: 3px solid ${m.colore}`}>
          <div class="card-sigla" style={`color: ${m.colore}`}>{m.sigla}</div>
          <div class="card-nome">{m.nome}</div>
          <div class="card-meta">{m.domande} domande</div>
          <div class="card-arrow">→</div>
        </a>
      ))}
    </div>
  </main>
</body>
</html>